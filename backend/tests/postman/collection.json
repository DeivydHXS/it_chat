			"name": "Auth",
			"item": [
				{
					"name": "Register User Success - 201 Created",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();\r",
									"\r",
									"pm.test('Status code should be 201 - Created', () => {\r",
									"    pm.response.to.have.status(201);\r",
									"});\r",
									"\r",
									"pm.test('TC_001 - it should register a new user with valid data.', () => {\r",
									"    pm.expect(jsonData.message).to.eql('Usuário criado com sucesso!');\r",
									"    pm.expect(jsonData.user).to.have.property('id').and.to.not.be.null;\r",
									"    pm.expect(jsonData.user).to.have.property('nickname');\r",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"const email = `user.${new Date().getTime()}@email.com`;\r",
									"pm.environment.set('userEmail', email);\r",
									"\r",
									"const password = `G${new Date().getTime()}@`;\r",
									"pm.environment.set('userPassword', password);\r",
									""
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n  \"name\": \"Test User\",\r\n  \"nickname\": \"SuperQA\",\r\n  \"email\": \"{{userEmail}}\",\r\n  \"bio\": \"Quality Analyst at It Universe\",\r\n  \"birthday\": \"2000/08/21\",\r\n  \"password\": \"{{userPassword}}\",\r\n  \"password_confirmation\": \"{{userPassword}}\",\r\n  \"profile_image\": \"https://url-da-imagem.com/avatar.png\"\r\n}",
							"options": {
